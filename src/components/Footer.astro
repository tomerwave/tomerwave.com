---
import Hr from "./Hr.astro";
import Socials from "./Socials.astro";

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
---

<footer class:list={["w-full", { "mt-auto": !noMarginTop }]}>
  <Hr noPadding />
  <div
    class="flex flex-col items-center justify-between py-6 sm:flex-row-reverse sm:py-4"
  >
    <Socials centered />
    <div class="my-2 flex flex-col items-center whitespace-nowrap sm:flex-row">
      <a href="https://github.com/tomerwave/tomerwave.com" target="_blank" rel="noopener noreferrer" class="hover:text-accent">
        Steal this post ➜ CC BY 4.0 · Code MIT
      </a>
    </div>
    <div class="text-xs opacity-60">
      Tip: Change tomerwave.com to <a href="https://tomerwave.md" class="hover:text-accent underline">tomerwave.md</a> for the markdown version.
    </div>
  </div>
</footer>
