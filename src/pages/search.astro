---
import "@pagefind/default-ui/css/ui.css";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";

const backUrl = SITE.showBackButton ? `${Astro.url.pathname}` : "/";
---

<Layout title={`Search | ${SITE.title}`} description="Search through blog posts.">
  <Header />
  <Main pageTitle="Search" pageDesc="Search any article ...">
    <div id="pagefind-search" transition:persist data-backurl={backUrl}></div>
  </Main>
  <Footer />
</Layout>

<script>
  async function initSearch() {
    const pageFindSearch = document.querySelector("#pagefind-search");
    if (!pageFindSearch || pageFindSearch.querySelector(".pagefind-ui")) return;

    const params = new URLSearchParams(window.location.search);

    try {
      // Check if search index exists in DEV mode
      if (import.meta.env.DEV) {
        const indexCheck = await fetch("/pagefind/pagefind.js", { method: "HEAD" }).catch(() => ({ ok: false }));
        if (!indexCheck.ok && !document.querySelector("#pagefind-dev-warning")) {
          const warning = document.createElement("div");
          warning.id = "pagefind-dev-warning";
          warning.className = "bg-muted/75 rounded p-4 space-y-4 mb-4 border border-accent/20";
          warning.innerHTML = `
              <p class="font-medium text-accent">Note: Search requires a build to function.</p>
              <p class="text-sm opacity-80">The search index is generated during the build process. To test search locally, run:</p>
              <code class="block bg-black/5 text-current px-2 py-1 rounded text-sm">npm run build && npm run preview</code>
            `;
          pageFindSearch.parentNode?.insertBefore(warning, pageFindSearch);
        }
      }

      // Dynamic import PagefindUI
      // @ts-expect-error — Missing types for @pagefind/default-ui package.
      const PagefindModule = await import("@pagefind/default-ui");
      const PagefindUI = PagefindModule.PagefindUI || PagefindModule.default;

      if (!PagefindUI) return;

      // Init pagefind ui
      const search = new PagefindUI({
        element: "#pagefind-search",
        bundlePath: "/pagefind/",
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: "Search posts, e.g. 'Code to Business'"
        },
        processTerm: function (term: string) {
          params.set("q", term);
          history.replaceState(history.state, "", "?" + params.toString());

          const backUrl = (pageFindSearch as HTMLElement)?.dataset?.backurl;
          sessionStorage.setItem("backUrl", backUrl + "?" + params.toString());

          return term;
        },
      });

      // If search param exists (eg: search?q=astro), trigger search
      const query = params.get("q");
      if (query) {
        search.triggerSearch(query);
      }

      // Auto-focus and placeholder
      setTimeout(() => {
        const searchInput = document.querySelector(".pagefind-ui__search-input") as HTMLInputElement;
        const clearButton = document.querySelector(".pagefind-ui__search-clear");
        
        if (searchInput) {
          searchInput.focus();
          
          searchInput.addEventListener("input", (e) => {
            if ((e.target as HTMLInputElement).value.trim() === "") {
              history.replaceState(history.state, "", window.location.pathname);
            }
          });
        }
        
        clearButton?.addEventListener("click", () => {
          history.replaceState(history.state, "", window.location.pathname);
        });
      }, 100);

    } catch (e) {
      console.error("Failed to initialize Pagefind:", e);
    }
  }

  // Use astro:page-load for initial load and view transitions
  document.addEventListener("astro:page-load", initSearch);
</script>

<style is:global>
  #pagefind-search {
    --pagefind-ui-font: var(--font-mono);
    --pagefind-ui-text: var(--foreground);
    --pagefind-ui-background: var(--background);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-tag: var(--background);
    --pagefind-ui-border-radius: 0.375rem;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;

    form::before {
      background-color: var(--foreground);
    }

    input {
      font-weight: 400;
      border: 1px solid var(--border);
    }

    input::placeholder {
      color: #6b7280;
      opacity: 1;
    }

    input:focus-visible {
      outline: 1px solid var(--accent);
    }

    .pagefind-ui__result-title a {
      color: var(--accent);
      outline-offset: 1px;
      outline-color: var(--accent);
    }

    .pagefind-ui__result-title a:focus-visible,
    .pagefind-ui__search-clear:focus-visible {
      text-decoration-line: none;
      outline-width: 2px;
      outline-style: dashed;
    }

    .pagefind-ui__result:last-of-type {
      border-bottom: 0;
    }

    .pagefind-ui__result-nested .pagefind-ui__result-link:before {
      font-family: system-ui;
    }
  }

  html[data-theme="dark"] #pagefind-search input::placeholder {
    color: #9ca3af;
  }
</style>
